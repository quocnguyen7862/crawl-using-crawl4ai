# Runtime directories
CRAWL4_AI_BASE_DIRECTORY=D:\MyPj\Crawl4AI\.crawl4ai-home
PYTHONIOENCODING=utf-8

# Crawl inputs
TOPCV_SEED_URLS=https://www.topcv.vn/viec-lam
TOPCV_OUTPUT=output/topcv_jobs.jsonl
TOPCV_OUTPUT_FORMAT=jsonl

# Crawl scope
TOPCV_MAX_LISTING_PAGES=1
TOPCV_MAX_JOBS=20

# Batch processing
TOPCV_BATCH_SIZE=10
TOPCV_BATCH_COOLDOWN=30

# Pacing
TOPCV_MAX_CONCURRENT=1
TOPCV_DELAY=8
TOPCV_DELAY_JITTER=3
TOPCV_RETRY=1
TOPCV_TIMEOUT_MS=45000
TOPCV_WAIT_FOR=

# Anti-block controls
TOPCV_BACKOFF_MULTIPLIER=2.5
TOPCV_BLOCK_THRESHOLD=1

# Browser and proxy
TOPCV_BROWSER_TYPE=firefox
TOPCV_PROXY_SERVER=http://brd.superproxy.io:33335
TOPCV_PROXY_USERNAME=your_brightdata_username
TOPCV_PROXY_PASSWORD=your_brightdata_password

# Output options
TOPCV_SHOW_ERRORS=true
